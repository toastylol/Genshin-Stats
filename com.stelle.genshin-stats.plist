<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stelle.genshin-stats</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string> 
        <string>/your/project/directory/enkaUser.js</string> <!-- be sure to change this to your actual directory -->
    </array>

    <key>WorkingDirectory</key>
    <string>/your/project/directory/</string> <!-- here too -->

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>0</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/genshin-stats.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/genshin-stats.err.log</string>
</dict>
</plist>
